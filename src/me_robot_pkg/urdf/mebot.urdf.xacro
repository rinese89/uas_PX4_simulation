<?xml version="1.0" ?>
<robot name="mebot" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- <xacro:include filename="$(find turtlebot3_description)/urdf/common_properties.urdf"/> -->

  <xacro:arg name="namespace" default=""/>
  <xacro:property name="namespace" value="$(arg namespace)"/>

  <!-- Init colour -->
  <material name="black">
      <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="dark">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <material name="light_black">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>

  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <link name="${namespace}base_footprint"/>

  <joint name="${namespace}base_to_base" type="fixed">
    <parent link="${namespace}base_footprint"/>
    <child link="${namespace}base_link" />
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
  </joint>

  <link name="${namespace}base_link">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="2.0 1.0 0.1"/>
      </geometry>
      <material name="light_black"/>
    </visual>

    <collision>
      <geometry>
        <box size="2.0 1.0 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.14395"/>
      <inertia ixx="0.095329" ixy="0" ixz="0"
               iyy="0.381317" iyz="0"
               izz="0.476646" />
    </inertial>
  </link>

  <joint name="${namespace}wheel_left_joint" type="continuous">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}wheel_left_link"/>
    <origin xyz="-0.5 0.6 0.0" rpy="-1.57 0 0"/> <!-- rotación de 90º sobre Y -->
    <axis xyz="0 0 1"/>
  </joint>

<link name="${namespace}wheel_left_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/> <!-- sin rotación adicional -->
    <geometry>
      <cylinder length="0.2" radius="0.4"/>
    </geometry>
    <material name="dark"/>
  </visual>

  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder length="0.2" radius="0.4"/>
    </geometry>
  </collision>

  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.043333" ixy="0.0" ixz="0.0"
             iyy="0.043333" iyz="0.0"
             izz="0.08"/>
  </inertial>
</link>

  <joint name="${namespace}wheel_right_joint" type="continuous">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}wheel_right_link"/>
    <origin xyz="-0.5 -0.6 0.0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="${namespace}wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.4"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.4"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="1.0" />
      <inertia ixx="043333" ixy="0.0" ixz="0.0"
               iyy="043333" iyz="0.0"
               izz="0.08" />
      </inertial>
  </link>

  <joint name="${namespace}caster_joint" type="fixed">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}caster_link"/>
    <origin xyz="0.8 0 -0.2" rpy="0 0 0"/>
  </joint>

  <link name="${namespace}caster_link">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0.8 0.0 -0.2" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.01" />
      <inertia ixx="0.016" ixy="0.0" ixz="0.0"
               iyy="0.016" iyz="0.0"
               izz="0.016" />
    </inertial>
  </link>

  <joint name="${namespace}scan_joint" type="fixed">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}base_scan"/>
    <origin xyz="0.8 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="${namespace}base_scan">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.2"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0.0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.2"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1.0" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.043333" ixy="0.0" ixz="0.0"
               iyy="0.043333" iyz="0.0"
               izz="0.08" />
    </inertial>
  </link>

</robot>