    <!--Joint LiDAR Link-->
    <joint name='scan_joint' type='fixed'>
        <pose relative_to='base_scan'/> 
        <parent>base_link</parent>
        <child>base_scan</child>
    </joint>

     <!--Lidar Link-->
    <link name='base_scan'>
        <pose relative_to="base_link"> -0.064000000000000001 0 0.122 0 0 0</pose>
        <inertial>
            <mass>0.0001</mass>
            <inertia>
                <ixx>0.00001</ixx>
                <ixy>0</ixy>
                <ixz>0</ixz>
                <iyy>0.00001</iyy>
                <iyz>0</iyz>
                <izz>0.00001</izz>
            </inertia>
        </inertial>
        <!--Sensor LiDAR definition-->
        <sensor name='gpu_lidar' type='gpu_lidar'>"
            <pose relative_to='base_scan'>0 0 0 0 0 0</pose>
            <topic>lidar_1</topic>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                    <samples>640</samples>
                    <resolution>1</resolution>
                    <min_angle>-1.396263</min_angle>
                    <max_angle>1.396263</max_angle>
                    </horizontal>
                    <vertical>
                    <samples>1</samples>
                    <resolution>0.01</resolution>
                    <min_angle>0</min_angle>
                    <max_angle>0</max_angle>
                    </vertical>
                </scan>
            <range>
                <min>0.08</min>
                <max>10.0</max>
                <resolution>0.01</resolution>
            </range>
            </ray>
            <always_on>1</always_on>
            <visualize>true</visualize>
        </sensor>
    </link>

    <joint name="aruco_joint" type="fixed">
      <pose relative_to='base_footprint'>-0.15 0 0.11 0 0 0</pose>
      <parent>base_footprint</parent>
      <child>aruco_marker_link</child>
    </joint>
    <link name='aruco_marker_link'>
    <pose relative_to='aruco_joint'>0 0 0 0 0 0</pose>
      <visual name='base_visual'>
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>0.1 0.1</size>
          </plane>
        </geometry>
        <material>
          <diffuse>1 1 1 1</diffuse>
          <specular>0.4 0.4 0.4 1</specular>
          <pbr>
            <metal>
              <albedo_map>file:///home/rinese/drone_px4_ws/src/PX4-Autopilot/Tools/simulation/gz/models/arucotag/arucotag.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>

     <!-- Plugin para ros2_control -->
     
    <ros2_control name="GazeboSimSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
      <joint name="wheel_left_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="wheel_right_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>/home/rinese/robot_ws/src/me_robot_pkg/config/ros2_controller_tb3.yaml</parameters>
        <robot_param>robot_description</robot_param>
        <robot_param_node>robot_state_publisher</robot_param_node>
        <ros>
          <param name="use_sim_time">true</param>
        </ros>
    </plugin>
    

  </model>
